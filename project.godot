config_version=5

[application]

config/name="The Fractured Signal Game"
config/version="0.0.1"
config/tags=PackedStringArray("game")
run/main_scene="uid://c2mwoxh82m4x4"
config/use_custom_user_dir=true
config/custom_user_dir_name="ChaptersSaves"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="uid://c5ueqalrhak6h"
boot_splash/stretch_mode=0
boot_splash/use_filter=false
boot_splash/image="uid://c5ueqalrhak6h"

[autoload]

DialogueManager="*uid://c3rodes2l3gxb"
