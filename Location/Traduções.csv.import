[remap]

importer="csv_translation"
type="Translation"
uid="uid://bxadv0m0yu7ix"

[deps]

files=["res://Location/Traduções.english.translation", "res://Location/Traduções.portuguese.translation"]

source_file="res://Location/Traduções.csv"
